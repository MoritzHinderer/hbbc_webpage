    "@tiptap/vue-3": "^3.27.1",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "leaflet": "^1.9.4",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
