# Test output
coverage/
test-results/
playwright-report/

# Backend secrets and local data
.env
server/data/

# Admin-editable runtime content (events/news/gallery/downloads/members
# JSON + all uploaded files) — lives on the server's own disk, same as
# server/data/ above. Must never be git-tracked: a deploy runs `git pull`,
# and a tracked file here could let a future commit silently overwrite or
# conflict with live admin-entered content.
server/content/

# Same reasoning as server/content/ above — this is the one piece of
# admin-editable content that lives under public/ instead (see
# content-store.ts's publicDir). Leaving it tracked let a fresh/reset VPS
# checkout ship a manifest referencing downloads that were never actually
# uploaded to that checkout's disk (issue #18).
public/downloads/downloads.json

