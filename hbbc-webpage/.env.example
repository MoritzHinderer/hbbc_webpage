# Copy to .env and fill in real values. Never commit .env.
PORT=3001

# SMTP credentials used to send contact-form and newsletter-signup mail.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where contact-form submissions and newsletter-signup notifications are sent.
CONTACT_TO_EMAIL=info@hbbc-fanclub.de
# Optional: defaults to SMTP_USER if unset.
CONTACT_FROM_EMAIL=no-reply@hbbc-fanclub.de

# Real identity/address for the /impressum page (legally required — see
# GET /api/impressum, server/routes/impressum.ts). Kept out of git on
# purpose: whoever deploys this fills in their own real details here.
# IMPRESSUM_PHONE is optional; leave unset to omit the phone line entirely.
# Without these set, the Impressum page shows a clear "not configured yet"
# notice instead of publishing incomplete/fake legal information.
IMPRESSUM_NAME=Max Mustermann
IMPRESSUM_ADDRESS_LINE1=Musterstraße 1
IMPRESSUM_ADDRESS_LINE2=12345 Musterstadt
IMPRESSUM_PHONE=
